# Optional server-only provider configuration. Never prefix secrets with VITE_.
OPENAI_API_KEY=
OPENAI_MEDICAL_MODEL=gpt-5.6
# Required in production when OPENAI_API_KEY is set; use at least 32 unpredictable characters.
OPENAI_SAFETY_IDENTIFIER_SALT=
PORT=3000
# Required on Vercel for cross-instance demo sessions. Provision Upstash Redis
# from Project Settings > Integrations; do not expose these to the browser.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# These are intentionally empty and are not required by the public demo.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
